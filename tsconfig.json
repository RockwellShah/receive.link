{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "WebWorker"],
    "types": ["@cloudflare/workers-types", "bun"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["shared", "worker/src", "scripts"],
  "//": "web/ (client + vendored core) is validated by bun build + bun test, not tsc. dev-link.ts imports the vendored core, so it's excluded here too.",
  "exclude": ["node_modules", "web/core", "scripts/dev-link.ts"]
}
