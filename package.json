{
  "name": "receive-link",
  "private": true,
  "version": "1.0.0",
  "description": "receive.link: give anyone a link; whatever they drop arrives end-to-end encrypted to your passkey.",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit && tsc --noEmit -p web/tsconfig.json",
    "typecheck:web": "tsc --noEmit -p web/tsconfig.json",
    "gen:keys": "bun run scripts/gen-keys.ts",
    "build:web": "bun run web/build.ts",
    "dev:web": "bun run web/serve.ts",
    "dev:mock": "bun run web/devserver.ts",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@hpke/core": "^1.9.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@paulmillr/qr": "^0.3.0",
    "@scure/base": "^2.2.0",
    "@scure/bip39": "^2.2.0",
    "aws4fetch": "^1.0.20",
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240000.0",
    "@types/bun": "^1.3.14",
    "typescript": "^5.6.0",
    "wrangler": "^3.80.0"
  }
}
